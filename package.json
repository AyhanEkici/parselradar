{
  "name": "parselradar-monorepo",
  "private": true,
  "scripts": {
    "postinstall": "npm install --prefix packages/shared && npm install --prefix apps/api && npm install --prefix apps/web",
    "dev": "concurrently \"npm run dev --prefix apps/api\" \"npm run dev --prefix apps/web\"",
    "typecheck": "npm run typecheck --prefix packages/shared && npm run typecheck --prefix apps/api && npm run typecheck --prefix apps/web",
    "lint": "npm run lint --prefix packages/shared && npm run lint --prefix apps/api && npm run lint --prefix apps/web",
    "build": "npm run build --prefix packages/shared && npm run build --prefix apps/api && npm run build --prefix apps/web",
    "verify:platform": "ts-node scripts/verify-platform.ts",
    "verify:rbac": "ts-node scripts/verify-rbac.ts",
    "verify:cors": "ts-node apps/api/scripts/verifyCorsConfig.ts",
    "verify:password-reset": "ts-node apps/api/scripts/verifyPasswordResetFlow.ts",
    "verify:live-api": "ts-node apps/api/scripts/verifyLiveApiTransport.ts",
    "verify:live-login-contract": "ts-node apps/api/scripts/verifyLiveLoginContract.ts",
    "verify:live-browser-auth": "ts-node apps/api/scripts/verifyLiveBrowserAuth.ts",
    "verify:runtime-boot": "ts-node apps/api/scripts/verifyRuntimeBoot.ts",
    "verify:railway-runtime": "ts-node apps/api/scripts/verifyRailwayRuntimeHealth.ts",
    "verify:deployment-truth": "ts-node apps/api/scripts/verifyDeploymentTruth.ts",
    "check:auth-routes": "ts-node apps/api/scripts/check-auth-routes.ts",
    "auth:diagnose": "ts-node apps/api/scripts/diagnoseAuthUsers.ts",
    "auth:verify-passwordhash": "ts-node apps/api/scripts/verifyPasswordHashField.ts",
    "auth:repair": "ts-node apps/api/scripts/repairSingleUserAuth.ts",
    "verify:passwords": "ts-node apps/api/scripts/verifyPasswordCompatibility.ts",
    "auth:repair-safe": "ts-node apps/api/scripts/repairAuthHashes.ts",
    "auth:reset-known-users": "ts-node apps/api/scripts/resetKnownUserPasswords.ts",
    "verify:login": "ts-node apps/api/scripts/verifyLoginFlow.ts",
    "verify:auth-loop": "ts-node apps/api/scripts/verifyAuthLoop.ts",
    "verify:post-login-api": "ts-node apps/api/scripts/verifyPostLoginApiStability.ts",
    "verify:session-persistence": "ts-node apps/api/scripts/verifySessionPersistence.ts",
    "verify:admin-ux-email": "ts-node apps/api/scripts/verifyAdminUxAndEmail.ts",
    "verify:auth-ui-consistency": "ts-node apps/api/scripts/verifyAuthUiConsistency.ts",
    "audit:mvp-wiring": "ts-node apps/api/scripts/auditMvpWiring.ts",
    "verify:mvp-wiring": "ts-node apps/api/scripts/verifyMvpWiring.ts",
    "verify:security": "ts-node scripts/verify-security.ts",
    "users:ensure-required": "ts-node apps/api/scripts/ensureRequiredUsers.ts",
    "check:admin-routes": "ts-node scripts/check-admin-api-routes.ts",
    "check:docker-backend": "ts-node scripts/check-docker-backend-build.ts",
    "verify:railway-docker": "ts-node scripts/verify-railway-deployment-mode.ts",
    "seed": "npm run seed --prefix apps/api",
    "test": "npm run test --prefix packages/shared && npm run test --prefix apps/api && npm run test --prefix apps/web",
    "smoke": "npm run smoke --prefix apps/api",
    "pilot:env": "npm run pilot:env --prefix apps/api",
    "pilot:checklist": "npm run pilot:checklist --prefix apps/api",
    "pilot:flow": "npm run pilot:flow --prefix apps/api",
    "start": "npm start --prefix apps/api"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "bullmq": "^5.76.10",
    "ioredis": "^5.10.1"
  }
}
